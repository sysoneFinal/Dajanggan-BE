# Google Cloud SQL (Production)
GOOGLE_DB_URL=jdbc:postgresql://YOUR_CLOUD_SQL_IP:5432/postgres
GOOGLE_DB_USERNAME=postgres
GOOGLE_DB_PASSWORD=YOUR_DB_PASSWORD

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD

# Encryption Keys
APP_CRYPTO_ACTIVE_KEY_ID=1
APP_CRYPTO_KEYS_V1=1:YOUR_ENCRYPTION_KEY
APP_CRYPTO_PBKDF2_ITER=200000
APP_CRYPTO_SALT_LEN=16
APP_CRYPTO_IV_LEN=12
