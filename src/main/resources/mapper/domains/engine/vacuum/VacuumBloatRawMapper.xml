<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.dajanggan.domain.vacuum.repository.VacuumBloatRawMapper">

    <!-- VacuumRawMetricDto ResultMap -->
    <resultMap id="vacuumRawMetricMap" type="com.dajanggan.domain.vacuum.dto.raw.VacuumRawMetricDto">
        <result column="database_id" property="databaseId"/>
        <result column="instance_id" property="instanceId"/>
        <result column="collected_at" property="collectedAt"/>
        <result column="table_name" property="tableName"/>
        <result column="schema_name" property="schemaName"/>
        <result column="session_phase" property="sessionPhase"/>
        <result column="session_progress" property="sessionProgress"/>
        <result column="autovacuum" property="autovacuum"/>
        <result column="heap_blks_total" property="heapBlksTotal"/>
        <result column="heap_blks_scanned" property="heapBlksScanned"/>
        <result column="heap_blks_vacuumed" property="heapBlksVacuumed"/>
        <result column="index_vacuum_count" property="indexVacuumCount"/>
        <result column="n_dead_tup" property="nDeadTup"/>
        <result column="n_live_tup" property="nLiveTup"/>
        <result column="n_mod_since_analyze" property="nModSinceAnalyze"/>
        <result column="tuples_deleted" property="tuplesDeleted"/>
        <result column="session_started_at" property="sessionStartedAt"/>
        <result column="elapsed_seconds" property="elapsedSeconds"/>
        <result column="session_trigger" property="sessionTrigger"/>
        <result column="relsize_total_bytes" property="relsizeTotalBytes"/>
        <result column="bloat_bytes" property="bloatBytes"/>
        <result column="bloat_ratio" property="bloatRatio"/>
        <result column="index_bloat_info" property="indexBloatInfo"/>
        <result column="blocker_xmin_horizon" property="blockerXminHorizon"/>
        <result column="blocked_seconds" property="blockedSeconds"/>
        <result column="last_vacuum" property="lastVacuum"/>
        <result column="last_autovacuum" property="lastAutovacuum"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <!-- Xmin Horizon 데이터 조회 -->
    <select id="findXminHorizonData" resultMap="vacuumRawMetricMap">
        SELECT
            database_id,
            instance_id,
            collected_at,
            table_name,
            blocker_xmin_horizon,
            tuples_deleted,
            elapsed_seconds
        FROM vacuum_raw_metrics
        WHERE database_id = #{databaseId}
          AND instance_id = #{instanceId}
          AND collected_at BETWEEN #{startTime} AND #{endTime}
          AND blocker_xmin_horizon IS NOT NULL
        ORDER BY collected_at ASC
    </select>

    <!-- 테이블 목록 조회 -->
    <select id="findTableList" resultType="string">
        SELECT DISTINCT table_name
        FROM vacuum_raw_metrics
        WHERE database_id = #{databaseId}
          AND instance_id = #{instanceId}
          AND table_name IS NOT NULL
          AND collected_at >= NOW() - INTERVAL '30 days'
        ORDER BY table_name
    </select>

    <!-- 특정 테이블의 최신 메트릭 -->
    <select id="findLatestByTable" resultMap="vacuumRawMetricMap">
        SELECT
            database_id,
            instance_id,
            collected_at,
            table_name,
            schema_name,
            bloat_bytes,
            bloat_ratio,
            relsize_total_bytes,
            n_dead_tup,
            n_live_tup,
            last_vacuum,
            last_autovacuum,
            index_bloat_info
        FROM vacuum_raw_metrics
        WHERE database_id = #{databaseId}
          AND instance_id = #{instanceId}
          AND table_name = #{tableName}
        ORDER BY collected_at DESC
            LIMIT 1
    </select>

    <!-- 특정 테이블의 Bloat 트렌드 -->
    <select id="findTableBloatTrend" resultMap="vacuumRawMetricMap">
        SELECT
            database_id,
            instance_id,
            collected_at,
            table_name,
            bloat_bytes,
            bloat_ratio,
            n_dead_tup,
            relsize_total_bytes,
            index_bloat_info
        FROM vacuum_raw_metrics
        WHERE database_id = #{databaseId}
          AND instance_id = #{instanceId}
          AND table_name = #{tableName}
          AND collected_at BETWEEN #{startTime} AND #{endTime}
        ORDER BY collected_at ASC
    </select>

</mapper>