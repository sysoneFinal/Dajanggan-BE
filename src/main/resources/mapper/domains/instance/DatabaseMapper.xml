<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    ========================================================================
    DatabaseMapper.xml - 데이터베이스 Repository MyBatis Mapper
    ========================================================================

    주요 기능:
    - 데이터베이스 정보 CRUD
    - DTO 직접 반환으로 성능 최적화 (조회)
    - Entity 반환으로 영속성 관리 (CUD)
    - N+1 문제 방지 (일괄 조회)

    테이블: monitor_database

    작성일: 2025-11-04
    작성자: 김민서
    ========================================================================
-->
<mapper namespace="com.dajanggan.domain.instance.repository.DatabaseRepository">

    <!-- ========================================================================
         ResultMap 정의
         ======================================================================== -->

    <!--
        DatabaseResponse DTO ResultMap

        용도: API 응답용 DTO
        특징:
        - 필요한 필드만 포함 (성능 최적화)
        - created_at 제외 (API 응답에 불필요)
    -->
    <resultMap id="databaseResponseMap" type="com.dajanggan.domain.instance.dto.DatabaseResponse">
        <id property="databaseId" column="database_id"/>
        <result property="instanceId" column="instance_id"/>
        <result property="databaseName" column="database_name"/>
        <result property="status" column="status"/>
        <result property="connections" column="connections"/>
        <result property="sizeBytes" column="size_bytes"/>
        <result property="cacheHitRate" column="cache_hit_rate"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!--
        Database Entity ResultMap

        용도: Service 내부 로직 (메트릭 수집, DB 동기화)
        특징: 모든 필드 포함 (영속성 관리)
    -->
    <resultMap id="databaseEntityMap" type="com.dajanggan.domain.instance.domain.Database">
        <id property="databaseId" column="database_id"/>
        <result property="instanceId" column="instance_id"/>
        <result property="databaseName" column="database_name"/>
        <result property="status" column="status"/>
        <result property="connections" column="connections"/>
        <result property="sizeBytes" column="size_bytes"/>
        <result property="cacheHitRate" column="cache_hit_rate"/>
        <result property="isEnabled" column="is_enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- ========================================================================
         조회 (Read) - DTO 반환 (API 응답용)
         ======================================================================== -->

    <!--
        인스턴스 ID로 데이터베이스 목록 조회

        반환 타입: DatabaseResponse (DTO)
        용도: GET /api/instances/{id}/databases
        조건: is_enabled = true (활성화된 DB만)
        정렬: database_name 오름차순
    -->
    <select id="findByInstanceId" resultMap="databaseResponseMap">
        SELECT
            database_id,
            instance_id,
            database_name,
            status,
            connections,
            size_bytes,
            cache_hit_rate,
            updated_at
        FROM monitor_database
        WHERE instance_id = #{instanceId}
          AND is_enabled = true
        ORDER BY database_name
    </select>

    <!--
        여러 인스턴스의 데이터베이스 일괄 조회 (N+1 방지)

        반환 타입: DatabaseResponse (DTO)
        용도: GET /api/instances?include=databases (성능 최적화)

        성능 최적화:
        - WHERE instance_id IN (...) 사용
        - 한 번의 쿼리로 여러 인스턴스의 DB 조회

        사용 예시:
        N+1 문제 발생:
            for (Instance i : instances) {
                findByInstanceId(i.getId());  // N번 쿼리
            }

        한 번의 쿼리로 해결:
            List<Long> ids = instances.stream()
                .map(Instance::getId)
                .toList();
            findByInstanceIds(ids);  // 1번 쿼리
    -->
    <select id="findByInstanceIds" resultMap="databaseResponseMap">
        SELECT
        database_id,
        instance_id,
        database_name,
        status,
        connections,
        size_bytes,
        cache_hit_rate,
        updated_at
        FROM monitor_database
        WHERE instance_id IN
        <foreach collection="list" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        AND is_enabled = true
        ORDER BY instance_id, database_name
    </select>

    <!-- ========================================================================
         조회 (Read) - Entity 반환 (내부 로직용)
         ======================================================================== -->

    <!--
        인스턴스 ID로 데이터베이스 엔티티 목록 조회

        반환 타입: Database (Entity)
        용도: Service 내부 로직 전용
        - 메트릭 수집
        - 데이터베이스 동기화
        - 대시보드 생성

        주의: Controller에 직접 반환 금지!

        특징:
        - is_enabled 포함 (활성/비활성 모두 조회)
        - created_at 포함 (전체 정보)
    -->
    <select id="findDatabaseEntitiesByInstanceId" resultMap="databaseEntityMap">
        SELECT
            database_id,
            instance_id,
            database_name,
            status,
            connections,
            size_bytes,
            cache_hit_rate,
            is_enabled,
            created_at,
            updated_at
        FROM monitor_database
        WHERE instance_id = #{instanceId}
        ORDER BY database_name
    </select>

    <!--
        메트릭 수집이 활성화된 모든 데이터베이스 조회

        반환 타입: Database (Entity)
        용도: 메트릭 수집 스케줄러 전용
        조건: is_enabled = true
        정렬: instance_id, database_id (메트릭 수집 순서)
    -->
    <select id="findAllEnabled" resultMap="databaseEntityMap">
        SELECT
            database_id,
            instance_id,
            database_name,
            status,
            connections,
            size_bytes,
            cache_hit_rate,
            is_enabled,
            created_at,
            updated_at
        FROM monitor_database
        WHERE is_enabled = true
        ORDER BY instance_id, database_id
    </select>

    <!--
        데이터베이스 ID로 단건 조회

        반환 타입: Database (Entity)
        용도:
        - EXPLAIN ANALYZE 쿼리 실행
        - 특정 DB 메트릭 수집
    -->
    <select id="findById" resultMap="databaseEntityMap">
        SELECT
            database_id,
            instance_id,
            database_name,
            status,
            connections,
            size_bytes,
            cache_hit_rate,
            is_enabled,
            created_at,
            updated_at
        FROM monitor_database
        WHERE database_id = #{databaseId}
    </select>

    <!-- ========================================================================
         생성 (Create)
         ======================================================================== -->

    <!--
        데이터베이스 레코드 삽입

        특징:
        - useGeneratedKeys="true": ID 자동 생성
        - keyProperty="databaseId": 생성된 ID를 객체에 자동 설정

        생성 후: database.getDatabaseId()로 ID 접근 가능

        기본값:
        - status: 'active' (COALESCE 사용)
        - is_enabled: true
        - created_at, updated_at: NOW()
    -->
    <insert id="insert"
            parameterType="com.dajanggan.domain.instance.domain.Database"
            useGeneratedKeys="true"
            keyProperty="databaseId">
        INSERT INTO monitor_database (
            instance_id,
            database_name,
            status,
            is_enabled,
            created_at,
            updated_at
        ) VALUES (
                     #{instanceId},
                     #{databaseName},
                     COALESCE(#{status}, 'active'),
                     COALESCE(#{isEnabled}, true),
                     NOW(),
                     NOW()
                 )
    </insert>

    <!-- ========================================================================
         수정 (Update)
         ======================================================================== -->

    <!--
        데이터베이스 정보 업데이트

        업데이트 가능 필드:
        - connections: 연결 수
        - size_bytes: 데이터베이스 크기
        - cache_hit_rate: 캐시 히트율
        - status: 상태 (active, inactive, error 등)
        - is_enabled: 활성화 여부

        자동 업데이트: updated_at = NOW()
    -->
    <update id="update">
        UPDATE monitor_database
        SET connections = #{connections},
            size_bytes = #{sizeBytes},
            cache_hit_rate = #{cacheHitRate},
            status = #{status},
            is_enabled = #{isEnabled},
            updated_at = NOW()
        WHERE database_id = #{databaseId}
    </update>

    <!--
        여러 데이터베이스 비활성화 (일괄)

        동작:
        - is_enabled = false로 업데이트
        - 실제 삭제는 하지 않음 (메트릭 데이터 보존)

        용도: 인스턴스 수정 시 삭제된 DB 비활성화

        처리 흐름:
        1. PostgreSQL 서버에서 현재 DB 목록 조회
        2. 로컬 DB 목록과 비교
        3. 사라진 DB는 비활성화 (DELETE 대신 UPDATE)
    -->
    <update id="deactivateByIds">
        UPDATE monitor_database
        SET is_enabled = false,
        updated_at = NOW()
        WHERE database_id IN
        <foreach collection="databaseIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <!-- ========================================================================
         삭제 (Delete)
         ======================================================================== -->

    <!--
        인스턴스에 속한 모든 데이터베이스 삭제

        동작: 물리적 삭제 (DELETE)
        용도: 인스턴스 삭제 시 연관 데이터 정리

        주의:
        - CASCADE 설정 확인 필요 (메트릭 데이터)
        - Service 레이어에서 메트릭 데이터 먼저 삭제 권장

        처리 순서:
        1. 메트릭 데이터 삭제 (선택)
        2. 데이터베이스 레코드 삭제 (이 쿼리)
        3. 인스턴스 레코드 삭제
    -->
    <delete id="deleteByInstanceId">
        DELETE FROM monitor_database
        WHERE instance_id = #{instanceId}
    </delete>

    <!--
        데이터베이스의 메트릭 데이터 삭제

        동작: session_metrics_raw 테이블에서 삭제
        용도: 데이터베이스 삭제 전 메트릭 데이터 정리

        주의: 대량 데이터 삭제 시 성능 이슈 가능
        권장: 배치 작업으로 처리하거나 파티션 사용
    -->
    <delete id="deleteMetricsByDatabaseId">
        DELETE FROM session_metrics_raw
        WHERE database_id = #{databaseId}
    </delete>

    <!-- ========================================================================
         통계/집계 (Optional)
         ======================================================================== -->

    <!--
        활성화된 데이터베이스 개수 조회

        용도: 대시보드 통계
        조건: is_enabled = true
    -->
    <select id="countActive" resultType="int">
        SELECT COUNT(*)
        FROM monitor_database
        WHERE is_enabled = true
    </select>

    <!--
        인스턴스별 데이터베이스 개수 조회

        용도: 대시보드 통계, 리소스 모니터링
        반환: 인스턴스 ID와 DB 개수
    -->
    <select id="countByInstance" resultType="map">
        SELECT
            instance_id as instanceId,
            COUNT(*) as databaseCount
        FROM monitor_database
        WHERE is_enabled = true
        GROUP BY instance_id
        ORDER BY instance_id
    </select>

</mapper>