<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<!--
    ========================================================================
    InstanceMapper.xml - 인스턴스 Repository MyBatis Mapper
    ========================================================================

    주요 기능:
    - PostgreSQL 인스턴스 정보 CRUD
    - Slack 알림 설정 관리
    - 메트릭 수집을 위한 인스턴스 조회 (secret_ref 포함)
    - 보안: 일반 조회 시 secret_ref 제외

    테이블: monitor_instance

    보안 정책:
    - 일반 조회: secret_ref 제외 (InstanceListResultMap)
    - 메트릭 수집: secret_ref 포함 (InstanceResultMap)
    - TypeHandler: SecretStringTypeHandler (자동 암호화/복호화)

    작성일: 2025-11-03
    작성자: 김민서
    ========================================================================
-->
<mapper namespace="com.dajanggan.domain.instance.repository.InstanceRepository">

    <!-- ========================================================================
         ResultMap 정의
         ======================================================================== -->

    <!--
        InstanceResultMap - 전체 필드 포함 (secret_ref 포함)

        용도:
        - INSERT/UPDATE 작업
        - 메트릭 수집 (PostgreSQL 연결)
        - findById (단건 조회)

        보안:
        - secret_ref: SecretStringTypeHandler 사용
        - 자동 암호화/복호화 처리

        주의: Controller에 직접 반환 금지!
    -->
    <resultMap id="InstanceResultMap" type="com.dajanggan.domain.instance.domain.Instance">
        <id property="instanceId" column="instance_id"/>
        <result property="instanceName" column="instance_name"/>
        <result property="host" column="host"/>
        <result property="port" column="port"/>
        <result property="userName" column="username"/>
        <!--
            secret_ref: 암호화된 비밀번호
            TypeHandler: 자동 암호화/복호화
        -->
        <result property="secretRef" column="secret_ref"
                typeHandler="com.dajanggan.global.crypto.mybatis.SecretStringTypeHandler"/>
        <result property="sslmode" column="sslmode"/>
        <result property="version" column="version"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <!-- Slack 설정 -->
        <result property="slackEnabled" column="slack_enabled"/>
        <result property="slackWebhookUrl" column="slack_webhook_url"/>
        <result property="slackChannel" column="slack_channel"/>
        <result property="slackMention" column="slack_mention"/>
    </resultMap>

    <!--
        InstanceListResultMap - secret_ref 제외

        용도:
        - 목록 조회 (findAll)
        - API 응답용

        보안: secret_ref 필드 제외

        특징:
        - Service에서 InstanceResponse.from()으로 DTO 변환
        - 민감 정보 노출 방지
    -->
    <resultMap id="InstanceListResultMap" type="com.dajanggan.domain.instance.domain.Instance">
        <id property="instanceId" column="instance_id"/>
        <result property="instanceName" column="instance_name"/>
        <result property="host" column="host"/>
        <result property="port" column="port"/>
        <result property="userName" column="username"/>
        <!-- secret_ref 제외 (보안) -->
        <result property="sslmode" column="sslmode"/>
        <result property="version" column="version"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <!-- Slack 설정 -->
        <result property="slackEnabled" column="slack_enabled"/>
        <result property="slackWebhookUrl" column="slack_webhook_url"/>
        <result property="slackChannel" column="slack_channel"/>
        <result property="slackMention" column="slack_mention"/>
    </resultMap>

    <!-- ========================================================================
         생성 (Create)
         ======================================================================== -->

    <!--
        인스턴스 생성

        특징:
        - useGeneratedKeys="true": ID 자동 생성
        - keyProperty="instanceId": 생성된 ID를 객체에 설정

        생성 후: instance.getInstanceId()로 ID 접근 가능

        TypeHandler:
        - SecretStringTypeHandler가 secret_ref 자동 암호화

        필수 필드:
        - instance_name: 인스턴스 이름
        - host: 호스트 주소
        - port: 포트 번호
        - username: PostgreSQL 사용자명
        - secret_ref: 비밀번호 (TypeHandler가 암호화)
        - sslmode: SSL 모드 (기본값: disable)

        선택 필드:
        - status: 상태 (기본값: active)
        - version: PostgreSQL 버전
    -->
    <insert id="createInstance"
            parameterType="com.dajanggan.domain.instance.domain.Instance"
            useGeneratedKeys="true"
            keyProperty="instanceId">
        INSERT INTO monitor_instance (
            instance_name,
            host,
            port,
            username,
            secret_ref,
            sslmode,
            version,
            created_at,
            updated_at
        ) VALUES (
                     #{instanceName},
                     #{host},
                     #{port},
                     #{userName},
                     #{secretRef, jdbcType=VARCHAR, typeHandler=com.dajanggan.global.crypto.mybatis.SecretStringTypeHandler},
                     #{sslmode},
                     COALESCE(#{status}, 'active'),
                     #{version},
                     NOW(),
                     NOW()
                 )
    </insert>

    <!-- ========================================================================
         조회 (Read) - 일반 조회
         ======================================================================== -->

    <!--
        인스턴스 ID로 조회 (secret_ref 포함)

        반환 타입: Instance (Entity)
        ResultMap: InstanceResultMap (secret_ref 포함)

        용도:
        - 단건 조회 API
        - 수정 전 조회

        주의:
        - Service에서 InstanceResponse.from()으로 DTO 변환
        - DTO 변환 시 secret_ref 자동 제외
    -->
    <select id="findById" resultMap="InstanceResultMap">
        SELECT
            instance_id,
            instance_name,
            host,
            port,
            username,
            secret_ref,
            sslmode,
            version,
            created_at,
            updated_at,
            slack_enabled,
            slack_webhook_url,
            slack_channel,
            slack_mention
        FROM monitor_instance
        WHERE instance_id = #{id}
    </select>

    <!--
        모든 인스턴스 조회 (secret_ref 제외)

        반환 타입: Instance (Entity)
        ResultMap: InstanceListResultMap (secret_ref 제외)

        용도: GET /api/instances

        보안: secret_ref 컬럼 조회 안 함
        정렬: instance_id 내림차순 (최신순)
    -->
    <select id="findAll" resultMap="InstanceListResultMap">
        SELECT
            instance_id,
            instance_name,
            host,
            port,
            username,
            -- secret_ref 제외 (보안)
            sslmode,
            version,
            created_at,
            updated_at,
            slack_enabled,
            slack_webhook_url,
            slack_channel,
            slack_mention
        FROM monitor_instance
        ORDER BY instance_id DESC
    </select>

    <!--
        인스턴스 이름으로 ID 조회

        반환 타입: Long (인스턴스 ID)

        용도:
        - OS Metric Agent 자동 매핑
        - 인스턴스 이름 기반 Slack 설정 업데이트

        사용 예시:
        ```java
        // OS Metric Agent가 전송한 instanceName으로 매핑
        Optional<Long> instanceId = repository.findIdByInstanceName("prod-db-01");
        ```
    -->
    <select id="findIdByInstanceName" resultType="java.lang.Long">
        SELECT instance_id
        FROM monitor_instance
        WHERE instance_name = #{instanceName}
            LIMIT 1
    </select>

    <!-- ========================================================================
         조회 (Read) - 메트릭 수집용 (secret_ref 포함)
         ======================================================================== -->

    <!--
        메트릭 수집을 위한 인스턴스 조회 (secret_ref 포함)

        반환 타입: Instance (Entity)
        ResultMap: InstanceResultMap (secret_ref 포함)

        보안 주의:
        - secret_ref(암호화된 비밀번호) 포함
        - 메트릭 수집 스케줄러 전용
        - Controller에서 호출 금지!

        용도:
        - PostgreSQL 연결하여 메트릭 수집
        - EXPLAIN ANALYZE 실행
        - 데이터베이스 목록 조회

        처리 흐름:
        1. 인스턴스 목록 조회 (secret_ref 포함)
        2. AesGcmService로 secret_ref 복호화
        3. PostgreSQL 연결
        4. 메트릭 수집

        파라미터:
        - instanceIds: 조회할 인스턴스 ID 목록
          - null이면 전체 조회
    -->
    <select id="findAllWithSecrets" resultMap="InstanceResultMap">
        SELECT
        instance_id,
        instance_name,
        host,
        port,
        username,
        secret_ref,  <!-- 메트릭 수집을 위해 포함 -->
        sslmode,
        version,
        created_at,
        updated_at,
        slack_enabled,
        slack_webhook_url,
        slack_channel,
        slack_mention
        FROM monitor_instance
        <where>
            <if test="instanceIds != null and instanceIds.size() > 0">
                AND instance_id IN
                <foreach collection="instanceIds" item="id" open="(" separator="," close=")">
                    #{id}
                </foreach>
            </if>
        </where>
        ORDER BY instance_id
    </select>

    <!-- ========================================================================
         수정 (Update) - 기본 정보
         ======================================================================== -->

    <!--
        인스턴스 기본 정보 업데이트

        업데이트 가능 필드:
        - instance_name: 인스턴스 이름
        - host: 호스트 주소
        - port: 포트 번호
        - username: 사용자명
        - secret_ref: 암호화된 비밀번호 (선택)
        - sslmode: SSL 모드
        - status: 상태
        - version: PostgreSQL 버전

        자동 업데이트: updated_at = NOW()

        주의:
        - secret_ref는 Service에서 암호화 후 전달
        - TypeHandler가 자동으로 암호화 처리
    -->
    <update id="updateInstance" parameterType="com.dajanggan.domain.instance.domain.Instance">
        UPDATE monitor_instance
        SET instance_name = #{instanceName},
            host = #{host},
            port = #{port},
            username = #{userName},
            secret_ref = #{secretRef, jdbcType=VARCHAR, typeHandler=com.dajanggan.global.crypto.mybatis.SecretStringTypeHandler},
            sslmode = #{sslmode},
            version = #{version},
            updated_at = NOW()
        WHERE instance_id = #{instanceId}
    </update>

    <!-- ========================================================================
         수정 (Update) - Slack 설정
         ======================================================================== -->

    <!--
        인스턴스 이름으로 Slack 설정 업데이트

        용도: OS Metric Agent가 인스턴스 이름으로 Slack 설정

        업데이트 필드:
        - slack_enabled: Slack 알림 활성화 여부
        - slack_webhook_url: Webhook URL
        - slack_channel: 채널명 (예: #alerts)
        - slack_mention: 멘션 대상 (예: @here, @channel)

        자동 업데이트: updated_at = NOW()
    -->
    <update id="updateSlackSettings">
        UPDATE monitor_instance
        SET slack_enabled = #{enabled},
            slack_webhook_url = #{webhookUrl},
            slack_channel = #{defaultChannel},
            slack_mention = #{mention},
            updated_at = NOW()
        WHERE instance_name = #{instanceName}
    </update>

    <!--
        인스턴스 ID로 Slack 설정 업데이트

        용도: 관리자 UI에서 Slack 설정

        업데이트 필드: updateSlackSettings()와 동일
    -->
    <update id="updateSlackSettingsById">
        UPDATE monitor_instance
        SET slack_enabled = #{enabled},
            slack_webhook_url = #{webhookUrl},
            slack_channel = #{defaultChannel},
            slack_mention = #{mention},
            updated_at = NOW()
        WHERE instance_id = #{instanceId}
    </update>

    <!-- ========================================================================
         삭제 (Delete) - Slack 설정
         ======================================================================== -->

    <!--
        인스턴스 ID로 Slack 설정 삭제/초기화

        동작:
        - slack_enabled = false
        - slack_webhook_url = NULL
        - slack_channel = NULL
        - slack_mention = NULL

        주의: 인스턴스 자체는 삭제하지 않음
    -->
    <update id="deleteSlackSettingsById">
        UPDATE monitor_instance
        SET slack_enabled = false,
            slack_webhook_url = NULL,
            slack_channel = NULL,
            slack_mention = NULL,
            updated_at = NOW()
        WHERE instance_id = #{instanceId}
    </update>

    <!--
        인스턴스 이름으로 Slack 설정 삭제/초기화

        동작: deleteSlackSettingsById()와 동일
    -->
    <update id="deleteSlackSettingsByName">
        UPDATE monitor_instance
        SET slack_enabled = false,
            slack_webhook_url = NULL,
            slack_channel = NULL,
            slack_mention = NULL,
            updated_at = NOW()
        WHERE instance_name = #{instanceName}
    </update>

    <!-- ========================================================================
         삭제 (Delete) - 인스턴스
         ======================================================================== -->

    <!--
        인스턴스 삭제

        동작: 물리적 삭제 (DELETE)

        연관 데이터 처리:
        - 데이터베이스: Service에서 먼저 삭제 필요
        - 메트릭 데이터: CASCADE 설정 확인 필요
        - 대시보드: CASCADE 설정 확인 필요

        주의: 연관 데이터 정리 후 호출

        처리 순서:
        1. 데이터베이스의 메트릭 삭제 (선택)
        2. 데이터베이스 레코드 삭제
        3. 인스턴스 레코드 삭제 (이 쿼리)
    -->
    <delete id="deleteById">
        DELETE FROM monitor_instance
        WHERE instance_id = #{id}
    </delete>

    <!-- ========================================================================
         유틸리티 쿼리
         ======================================================================== -->

    <!--
        인스턴스 이름 존재 여부 확인

        용도: 중복 이름 검증 (인스턴스 생성/수정 시)
        반환: boolean (존재하면 true)
    -->
    <select id="existsByName" resultType="boolean">
        SELECT EXISTS(
            SELECT 1
            FROM monitor_instance
            WHERE instance_name = #{instanceName}
        )
    </select>

    <!-- ========================================================================
         통계/집계 (Optional)
         ======================================================================== -->

    <!--
        활성 인스턴스 개수 조회

        용도: 대시보드 통계
        조건: status = 'active'
    -->
    <select id="countActive" resultType="int">
        SELECT COUNT(*)
        FROM monitor_instance
        WHERE status = 'active'
    </select>

    <!--
        인스턴스별 데이터베이스 개수 조회

        용도: 대시보드 통계, 리소스 모니터링
        반환: 인스턴스 정보와 DB 개수
    -->
    <select id="countDatabasesByInstance" resultType="map">
        SELECT
            i.instance_id as instanceId,
            i.instance_name as instanceName,
            COUNT(d.database_id) as databaseCount
        FROM monitor_instance i
                 LEFT JOIN monitor_database d ON i.instance_id = d.instance_id
        WHERE d.is_enabled = true
        GROUP BY i.instance_id, i.instance_name
        ORDER BY i.instance_id
    </select>

</mapper>